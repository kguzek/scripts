#!/usr/bin/env zsh

set -e

script_name=${0:t}
dry_run=false
max_concurrent_checks=16
tmp_root=/tmp/update-containers-script

case "${1:-}" in
  --dry-run|-n)
    dry_run=true
    shift
    ;;
  "")
    ;;
  *)
    echo "Usage: $script_name [--dry-run|-n]" >&2
    exit 2
    ;;
esac

if [ "$#" -ne 0 ]; then
  echo "Usage: $script_name [--dry-run|-n]" >&2
  exit 2
fi

for required_command in log-status time-script; do
  if command -v "$required_command" >/dev/null 2>&1; then
    continue
  fi

  echo "[x] Missing required command: $required_command" >&2
  exit 1
done

source <(time-script --start)

remote_digest() {
  docker buildx imagetools inspect "$1" --format '{{.Manifest.Digest}}'
}

local_digests() {
  docker image inspect --format '{{range .RepoDigests}}{{println .}}{{end}}' "$1" 2>/dev/null \
    | cut -d@ -f2
}

image_is_pinned() {
  [[ "$1" == *@sha256:* ]]
}

image_exists_locally() {
  docker image inspect "$1" >/dev/null 2>&1
}

compose_needs_pull() {
  local image remote
  local needs_pull=false
  local -a images

  images=(${(f)"$(docker compose config --images)"})

  for image in "${images[@]}"; do
    if image_is_pinned "$image"; then
      if ! image_exists_locally "$image"; then
        log-status changed "Missing local image: $image"
        needs_pull=true
      fi

      continue
    fi

    remote=$(remote_digest "$image")

    if ! local_digests "$image" | grep -qx "$remote"; then
      log-status changed "Update available: $image"
      needs_pull=true
    fi
  done

  [ "$needs_pull" = true ]
}

check_compose_project() {
  local compose_file="$1"
  local result_file="$2"
  local container_dir project_name

  container_dir=$(dirname "$compose_file")

  (
    cd "$container_dir"

    log-status info "Checking $container_dir"
    project_name="$(basename "$container_dir")"

    if compose_needs_pull; then
      print -r -- "$container_dir" > "$result_file"
    else
      log-status unchanged "$project_name is up to date"
    fi
  )
}

wait_for_checks() {
  local pid

  for pid in "${check_pids[@]}"; do
    if ! wait "$pid"; then
      check_failures=$((check_failures + 1))
    fi
  done

  check_pids=()
}

mkdir -p "$tmp_root"
tmp_dir=$(mktemp -d "$tmp_root/run.XXXXXXXXXX")
trap 'rm -rf "$tmp_dir"' EXIT

compose_files=(/data/apps/*/compose.yaml(N) /opt/*/compose.yaml(N))
check_failures=0
check_index=0
check_pids=()

for compose_file in "${compose_files[@]}"; do
  check_index=$((check_index + 1))
  check_compose_project "$compose_file" "$tmp_dir/$check_index" &
  check_pids+=("$!")

  if (( ${#check_pids} >= max_concurrent_checks )); then
    wait_for_checks
  fi
done

wait_for_checks

if (( check_failures > 0 )); then
  log-status failed "$check_failures container check(s) failed"
  exit 1
fi

for result_file in "$tmp_dir"/*(Nn); do
  container_dir=$(<"$result_file")
  project_name="$(basename "$container_dir")"

  cd "$container_dir"

  if [ "$dry_run" = true ]; then
    log-status changed "Would update $project_name"
  else
    log-status changed "Updating $project_name"
    docker compose pull
    docker compose down
    docker compose up -d
  fi
done


if [ "$dry_run" = true ]; then
  updated_verb="checked for updates"
else
  updated_verb="updated"
fi
  log-status complete "All containers $updated_verb in $(time-script --end)s"
