#!/bin/sh

set -e

log_failure() {
  local program_name="$0"
  local line_number="$1"
  local line_content="$(sed -n "$line_number"p "$program_name")"
  log-status failed "System startup failed on line $line_number: $line_content"
}

trap 'log_failure $LINENO' ERR

log-status info "Starting Guzek VPN..."
if ! wg show | grep guzek-vpn-peer >/dev/null; then
  wg-quick up guzek-vpn-peer
else
  log-status unchanged "Guzek VPN already running"
fi

echo
log-status info "Starting Harbor containers"
cd /opt/harbor
docker compose up -d

echo
log-status complete "All privileged systems started successfully"
