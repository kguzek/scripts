#!/usr/bin/env zsh

set -e

program_name="${0:t}"
script_dir="${0:A:h}"
env_file="${script_dir:h}/cloudflare.env"

api_token_help="Create a Cloudflare API token with these steps:
1. Open dash.cloudflare.com.
2. Expand 'Manage account' in the sidebar.
3. Open 'Account API tokens'.
4. Create a new token and give it a clear name, such as 'cf script'.
5. For the first policy, keep the scope set to 'Entire Account'.
6. Add 'Cloudflare One / Zero Trust' > 'Cloudflare One Connector: cloudflared' with Read and Edit permissions.
7. Add another policy at the bottom.
8. Change the new policy scope to 'All Domains'.
9. Add 'DNS & Zones' > 'DNS' with Read and Edit permissions.
10. Save the token in $env_file as CLOUDFLARE_API_TOKEN."

print_usage() {
  local level="${1:-info}"
  log-status "$level" "Usage: $program_name [-h|--help] COMMAND

Commands:
  tunnel|tunnels                         List Cloudflare tunnels
  route|routes TUNNEL                    List ingress routes for a tunnel
  route|routes TUNNEL add HOST SERVICE   Add an ingress route to a tunnel
  route|routes TUNNEL edit ROUTE SERVICE Edit a route service by hostname or number
  route|routes TUNNEL edit ROUTE HOST SERVICE
                                          Edit a route hostname and service
  route|routes TUNNEL delete ROUTE       Delete an ingress route by hostname or number
  dns add NAME [--type TYPE] TARGET      Add a DNS record, default type A
  dns edit NAME [--type TYPE] TARGET     Edit a DNS record content and type
  dns delete|remove NAME                 Delete a DNS record

Tunnel matching is case-insensitive and word-based.
Route add/edit/delete also creates, updates, or deletes matching proxied DNS CNAME records.
Route config and numbering are cached for 10 minutes in /tmp/scripts/cf-routes-<tunnel-id>.json.

Examples:
  $program_name tunnels
  $program_name tunnel
  $program_name routes hp
  $program_name route gliwice
  $program_name routes gliwice
  $program_name routes hp add xxx.guzek.uk http://localhost
  $program_name routes hp edit 2 http://localhost:3000
  $program_name routes hp edit xxx.guzek.uk new.guzek.uk http://localhost:3000
  $program_name routes hp delete xxx.guzek.uk
  $program_name routes hp delete 2
  $program_name dns add a.example.com 192.168.0.1
  $program_name dns add b.example.com --type cname a.example.com
  $program_name dns edit a.example.com 192.168.0.2
  $program_name dns remove b.example.com

Secrets are loaded from: $env_file
Required variables: CLOUDFLARE_ACCOUNT_ID, CLOUDFLARE_API_TOKEN"
}

fail() {
  log-status failed "$*"
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

load_env() {
  [[ -f "$env_file" ]] || fail "Missing secrets file: $env_file"
  source "$env_file"

  [[ -n "${CLOUDFLARE_ACCOUNT_ID:-}" ]] || fail "Missing CLOUDFLARE_ACCOUNT_ID in $env_file"
  if [[ -z "${CLOUDFLARE_API_TOKEN:-}" ]]; then
    log-status failed "Missing CLOUDFLARE_API_TOKEN in $env_file"
    log-status info "$api_token_help"
    exit 1
  fi
}

cf_api() {
  local method="$1"
  local api_path="$2"
  local data="${3:-}"
  local response http_status body
  local args=(
    -sS
    -X "$method"
    -H "Authorization: Bearer $CLOUDFLARE_API_TOKEN"
    -H "Content-Type: application/json"
    -w $'\n%{http_code}'
  )

  if [[ -n "$data" ]]; then
    args+=(--data "$data")
  fi

  response="$(curl "${args[@]}" "https://api.cloudflare.com/client/v4$api_path")"
  http_status="${response##*$'\n'}"
  body="${response%$'\n'$http_status}"

  if [[ "$http_status" == 401 || "$http_status" == 403 ]]; then
    log-status failed "Cloudflare API returned HTTP $http_status"
    log-status info "$api_token_help"
    exit 1
  fi

  print -r -- "$body"
}

require_success() {
  local response="$1"
  local message="$2"

  if ! jq -e '.success == true' >/dev/null <<< "$response"; then
    log-status failed "$message"
    jq -r '.errors[]? | "- " + (.message // "unknown error")' >&2 <<< "$response"
    exit 1
  fi
}

tunnels_path() {
  printf '/accounts/%s/cfd_tunnel?is_deleted=false&per_page=100' "$CLOUDFLARE_ACCOUNT_ID"
}

tunnel_config_path() {
  printf '/accounts/%s/cfd_tunnel/%s/configurations' "$CLOUDFLARE_ACCOUNT_ID" "$1"
}

zones_path() {
  printf '/zones?account.id=%s&per_page=100' "$CLOUDFLARE_ACCOUNT_ID"
}

dns_records_path() {
  printf '/zones/%s/dns_records?per_page=5000' "$1"
}

dns_record_path() {
  printf '/zones/%s/dns_records/%s' "$1" "$2"
}

tunnel_dns_target() {
  printf '%s.cfargotunnel.com' "$found_tunnel_id"
}

route_cache_path() {
  printf '/tmp/scripts/cf-routes-%s.json' "$found_tunnel_id"
}

write_route_cache_from_config() {
  local config="$1"
  local cache_file now

  mkdir -p /tmp/scripts
  zmodload zsh/datetime 2>/dev/null || true
  now="${EPOCHSECONDS:-0}"
  cache_file="$(route_cache_path)"

  jq -n \
    --arg tunnel_id "$found_tunnel_id" \
    --arg tunnel_name "$found_tunnel_name" \
    --argjson generated_at "$now" \
    --argjson config "$config" '
      {
        tunnel_id: $tunnel_id,
        tunnel_name: $tunnel_name,
        generated_at: $generated_at,
        config: $config,
        routes: (
          [$config.ingress[]? | select(.hostname != null)]
          | to_entries
          | map({number: (.key + 1), hostname: .value.hostname, service: .value.service})
        )
      }
    ' > "$cache_file"
}

write_route_cache() {
  local response="$1"
  local config

  config="$(jq '.result.config // {}' <<< "$response")"
  write_route_cache_from_config "$config"
}

is_route_cache_fresh() {
  local cache_file="$1"
  local now mtime
  local -A cache_stat

  [[ -f "$cache_file" ]] || return 1
  zmodload zsh/stat zsh/datetime 2>/dev/null || return 1
  zstat -H cache_stat -- "$cache_file" || return 1

  now="$EPOCHSECONDS"
  mtime="$cache_stat[mtime]"

  (( now - mtime <= 600 ))
}

resolve_cached_route_number() {
  local route_number="$1"
  local cache_file route

  cache_file="$(route_cache_path)"
  is_route_cache_fresh "$cache_file" || return 1
  jq -e '.config.ingress | type == "array"' "$cache_file" >/dev/null || return 1

  cached_config="$(jq '.config // {}' "$cache_file")"
  route="$(jq -r --argjson route_number "$route_number" '
    .routes[]?
    | select(.number == $route_number)
    | [.hostname, .service]
    | @tsv
  ' "$cache_file")"

  if [[ -z "$route" ]]; then
    fail "No route numbered $route_number in cached routes for $found_tunnel_name; run '$program_name routes $found_tunnel_name' to refresh"
  fi

  cached_route_hostname="${route%%$'\t'*}"
  cached_route_service="${route#*$'\t'}"
  log-status unchanged "Using cached route [$route_number] $cached_route_hostname -> $cached_route_service"
  return 0
}

load_cached_config() {
  local cache_file

  cache_file="$(route_cache_path)"
  is_route_cache_fresh "$cache_file" || return 1
  jq -e '.config.ingress | type == "array"' "$cache_file" >/dev/null || return 1

  cached_config="$(jq '.config // {}' "$cache_file")"
  return 0
}

require_cached_config() {
  if load_cached_config; then
    return
  fi

  fail "Route cache is missing or older than 10 minutes for $found_tunnel_name; run '$program_name routes $found_tunnel_name' first"
}

find_zone_for_hostname() {
  local hostname="$1"
  local lookup_hostname response match

  lookup_hostname="${hostname#\*.}"
  response="$(cf_api GET "$(zones_path)")"
  require_success "$response" "Failed to list Cloudflare zones"

  match="$(jq -r --arg hostname "$lookup_hostname" '
    ($hostname | ascii_downcase) as $host
    | .result
    | map(
        . as $zone
        | ($zone.name | ascii_downcase) as $zone_name
        | select(($host == $zone_name) or ($host | endswith("." + $zone_name)))
      )
    | sort_by(.name | length)
    | reverse
    | first // empty
    | [.id, .name]
    | @tsv
  ' <<< "$response")"

  [[ -n "$match" ]] || fail "No Cloudflare zone found for $hostname"

  found_zone_id="${match%%$'\t'*}"
  found_zone_name="${match#*$'\t'}"
}

find_dns_record_for_hostname() {
  local hostname="$1"
  local response match

  response="$(cf_api GET "$(dns_records_path "$found_zone_id")")"
  require_success "$response" "Failed to list DNS records for $found_zone_name"

  match="$(jq -r --arg hostname "$hostname" '
    ($hostname | ascii_downcase) as $host
    | [.result[]? | select((.name | ascii_downcase) == $host)]
    | first // empty
    | [.id, .type, .content, (.proxied | tostring)]
    | @tsv
  ' <<< "$response")"

  if [[ -z "$match" ]]; then
    found_dns_record_id=''
    found_dns_record_type=''
    found_dns_record_content=''
    found_dns_record_proxied=''
    return
  fi

  found_dns_record_id="${match%%$'\t'*}"
  match="${match#*$'\t'}"
  found_dns_record_type="${match%%$'\t'*}"
  match="${match#*$'\t'}"
  found_dns_record_content="${match%%$'\t'*}"
  found_dns_record_proxied="${match#*$'\t'}"
}

normalize_dns_type() {
  local type="$1"

  print -r -- "${type:u}"
}

dns_record_payload() {
  local hostname="$1"
  local type="$2"
  local target="$3"
  local proxied="${4:-}"

  if [[ -n "$proxied" ]]; then
    jq -n --arg type "$type" --arg name "$hostname" --arg content "$target" --argjson proxied "$proxied" \
      '{type: $type, name: $name, content: $content, proxied: $proxied, ttl: 1}'
  else
    jq -n --arg type "$type" --arg name "$hostname" --arg content "$target" \
      '{type: $type, name: $name, content: $content, ttl: 1}'
  fi
}

create_dns_record() {
  local hostname="$1"
  local type="$2"
  local target="$3"
  local proxied="${4:-}"
  local payload response

  payload="$(dns_record_payload "$hostname" "$type" "$target" "$proxied")"
  response="$(cf_api POST "$(dns_records_path "$found_zone_id")" "$payload")"
  require_success "$response" "Failed to create DNS record for $hostname"
  log-status complete "Created DNS $hostname -> $target"
}

update_dns_record() {
  local hostname="$1"
  local type="$2"
  local target="$3"
  local proxied="${4:-}"
  local payload response

  payload="$(dns_record_payload "$hostname" "$type" "$target" "$proxied")"
  response="$(cf_api PUT "$(dns_record_path "$found_zone_id" "$found_dns_record_id")" "$payload")"
  require_success "$response" "Failed to update DNS record for $hostname"
  log-status complete "Updated DNS $hostname -> $target"
}

remove_found_dns_record() {
  local hostname="$1"
  local target="$2"
  local response

  response="$(cf_api DELETE "$(dns_record_path "$found_zone_id" "$found_dns_record_id")")"
  require_success "$response" "Failed to delete DNS record for $hostname"
  log-status complete "Deleted DNS $hostname -> $target"
}

upsert_dns_record() {
  local hostname="$1"
  local target

  find_zone_for_hostname "$hostname"
  find_dns_record_for_hostname "$hostname"

  target="$(tunnel_dns_target)"

  if [[ -z "$found_dns_record_id" ]]; then
    create_dns_record "$hostname" CNAME "$target" true
    return
  fi

  if [[ "$found_dns_record_type" != CNAME ]]; then
    fail "DNS record for $hostname already exists as $found_dns_record_type; refusing to replace it"
  fi

  if [[ "$found_dns_record_content" == "$target" && "$found_dns_record_proxied" == true ]]; then
    log-status unchanged "DNS already points $hostname -> $target"
    return
  fi

  update_dns_record "$hostname" CNAME "$target" true
}

delete_dns_record() {
  local hostname="$1"
  local target

  find_zone_for_hostname "$hostname"
  find_dns_record_for_hostname "$hostname"

  if [[ -z "$found_dns_record_id" ]]; then
    log-status warn "No DNS record found for $hostname"
    return
  fi

  target="$(tunnel_dns_target)"

  if [[ "$found_dns_record_type" != CNAME || "$found_dns_record_content" != "$target" ]]; then
    log-status warn "DNS record for $hostname does not point to $target; leaving it unchanged"
    return
  fi

  remove_found_dns_record "$hostname" "$target"
}

add_dns_record() {
  local hostname="$1"
  local type="$2"
  local target="$3"

  find_zone_for_hostname "$hostname"
  find_dns_record_for_hostname "$hostname"

  if [[ -n "$found_dns_record_id" ]]; then
    fail "DNS record already exists for $hostname in $found_zone_name"
  fi

  create_dns_record "$hostname" "$type" "$target"
}

edit_dns_record() {
  local hostname="$1"
  local type="$2"
  local target="$3"

  find_zone_for_hostname "$hostname"
  find_dns_record_for_hostname "$hostname"

  if [[ -z "$found_dns_record_id" ]]; then
    fail "No DNS record for $hostname in $found_zone_name"
  fi

  update_dns_record "$hostname" "$type" "$target"
}

delete_any_dns_record() {
  local hostname="$1"

  find_zone_for_hostname "$hostname"
  find_dns_record_for_hostname "$hostname"

  if [[ -z "$found_dns_record_id" ]]; then
    fail "No DNS record for $hostname in $found_zone_name"
  fi

  remove_found_dns_record "$hostname" "$found_dns_record_content"
}

parse_dns_record_args() {
  local type="A"
  local option
  parsed_dns_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)
        shift
        [[ $# -gt 0 ]] || return 2
        type="$1"
        [[ "$type" != --* ]] || return 2
        ;;
      --type=*)
        option="$1"
        type="${option#--type=}"
        [[ -n "$type" && "$type" != --* ]] || return 2
        ;;
      --*)
        return 2
        ;;
      *)
        parsed_dns_args+=("$1")
        ;;
    esac
    shift
  done

  parsed_dns_type="$(normalize_dns_type "$type")"
}

list_tunnels() {
  local response
  response="$(cf_api GET "$(tunnels_path)")"
  require_success "$response" "Failed to list Cloudflare tunnels"

  if [[ "$(jq '.result | length' <<< "$response")" == 0 ]]; then
    log-status info "No Cloudflare tunnels found"
    return
  fi

  log-status info "List of Cloudflare tunnels:"
  jq -r '.result[] | [.name, (.status // "unknown"), .id] | @tsv' <<< "$response" | while IFS=$'\t' read -r name tunnel_status id; do
    if [[ "$tunnel_status" == healthy ]]; then
      log-status complete "$name [$tunnel_status] $id"
    else
      log-status failed "$name [$tunnel_status] $id"
    fi
  done
}

find_tunnel() {
  local selector="$1"
  local response matches count match
  local -a match_lines

  response="$(cf_api GET "$(tunnels_path)")"
  require_success "$response" "Failed to list Cloudflare tunnels"

  matches="$(jq -r --arg query "$selector" '
    def words: ascii_downcase | gsub("[^[:alnum:]]+"; " ") | split(" ") | map(select(length > 0));

    ($query | words) as $query_words
    | .result
    | map(select(
        (.name | words) as $name_words
        | all($query_words[]; . as $query_word | any($name_words[]; . == $query_word))
      ))
    | .[]
    | [.id, .name] | @tsv
  ' <<< "$response")"

  if [[ -z "$matches" ]]; then
    count=0
  else
    match_lines=("${(@f)matches}")
    count="${#match_lines}"
  fi

  if [[ "$count" == 0 ]]; then
    log-status failed "No tunnel matched: $selector"
    log-status info "Available tunnels:"
    tunnel_number=1
    jq -r '.result[] | .name' <<< "$response" | while read -r name; do
      log-status numbered "$tunnel_number" "$name"
      (( tunnel_number++ ))
    done
    exit 1
  fi

  if [[ "$count" != 1 ]]; then
    log-status failed "Multiple tunnels matched: $selector"
    tunnel_number=1
    print -r -- "$matches" | while IFS=$'\t' read -r _ name; do
      log-status numbered "$tunnel_number" "$name"
      (( tunnel_number++ ))
    done
    exit 1
  fi

  match="$matches"
  found_tunnel_id="${match%%$'\t'*}"
  found_tunnel_name="${match#*$'\t'}"
}

list_routes() {
  local selector="$1"
  local response route_count route_number

  find_tunnel "$selector"

  response="$(cf_api GET "$(tunnel_config_path "$found_tunnel_id")")"
  require_success "$response" "Failed to load routes for tunnel: $found_tunnel_name"
  write_route_cache "$response"

  route_count="$(jq '[.result.config.ingress[]? | select(.hostname != null)] | length' <<< "$response")"
  log-status info "Routes for $found_tunnel_name:"

  if [[ "$route_count" == 0 ]]; then
    log-status failed "No hostname routes configured"
    return
  fi

  route_number=1
  jq -r '
    .result.config.ingress[]?
    | select(.hostname != null)
    | .hostname + " -> " + .service
  ' <<< "$response" | while read -r route; do
    log-status numbered "$route_number" "$route"
    (( route_number++ ))
  done
}

delete_route() {
  local selector="$1"
  local route_target="$2"
  local config new_config payload update_response deleted_hostname deleted_service deleted_route

  find_tunnel "$selector"
  require_cached_config
  config="$cached_config"

  if [[ "$route_target" == <-> && "$route_target" -gt 0 ]] && resolve_cached_route_number "$route_target"; then
    route_target="$cached_route_hostname"
  fi

  if [[ "$route_target" == <-> && "$route_target" -gt 0 ]]; then
    deleted_route="$(jq -r --argjson route_number "$route_target" '
      [.ingress[]? | select(.hostname != null)]
      | .[$route_number - 1] // empty
      | [.hostname, .service]
      | @tsv
    ' <<< "$config")"

    if [[ -z "$deleted_route" ]]; then
      fail "No route numbered $route_target in $found_tunnel_name"
    fi

    deleted_hostname="${deleted_route%%$'\t'*}"
    deleted_service="${deleted_route#*$'\t'}"
    new_config="$(jq --argjson route_number "$route_target" '
      .ingress = (
        (.ingress // []) as $ingress
        | reduce $ingress[] as $rule (
            {routes_seen: 0, rules: []};
            if $rule.hostname != null then
              .routes_seen += 1
              | if .routes_seen == $route_number then . else .rules += [$rule] end
            else
              .rules += [$rule]
            end
          )
        | .rules
      )
    ' <<< "$config")"
  else
    deleted_route="$(jq -r --arg hostname "$route_target" '
      [.ingress[]? | select(.hostname == $hostname)]
      | first // empty
      | [.hostname, .service]
      | @tsv
    ' <<< "$config")"

    if [[ -z "$deleted_route" ]]; then
      fail "No route for $route_target in $found_tunnel_name"
    fi

    deleted_hostname="${deleted_route%%$'\t'*}"
    deleted_service="${deleted_route#*$'\t'}"
    new_config="$(jq --arg hostname "$route_target" '
      .ingress = ((.ingress // []) | map(select(.hostname != $hostname)))
    ' <<< "$config")"
  fi

  payload="$(jq -n --argjson config "$new_config" '{config: $config}')"
  update_response="$(cf_api PUT "$(tunnel_config_path "$found_tunnel_id")" "$payload")"
  require_success "$update_response" "Failed to delete route from tunnel: $found_tunnel_name"
  write_route_cache_from_config "$new_config"

  delete_dns_record "$deleted_hostname"

  log-status complete "Deleted $deleted_hostname -> $deleted_service from $found_tunnel_name"
}

edit_route() {
  local selector="$1"
  local route_target="$2"
  local new_hostname="$3"
  local new_service="$4"
  local config new_config payload update_response existing_route existing_hostname existing_service duplicate

  find_tunnel "$selector"
  require_cached_config
  config="$cached_config"

  if [[ "$route_target" == <-> && "$route_target" -gt 0 ]] && resolve_cached_route_number "$route_target"; then
    route_target="$cached_route_hostname"
  fi

  if [[ "$route_target" == <-> && "$route_target" -gt 0 ]]; then
    existing_route="$(jq -r --argjson route_number "$route_target" '
      [.ingress[]? | select(.hostname != null)]
      | .[$route_number - 1] // empty
      | [.hostname, .service]
      | @tsv
    ' <<< "$config")"
  else
    existing_route="$(jq -r --arg hostname "$route_target" '
      [.ingress[]? | select(.hostname == $hostname)]
      | first // empty
      | [.hostname, .service]
      | @tsv
    ' <<< "$config")"
  fi

  if [[ -z "$existing_route" ]]; then
    if [[ "$route_target" == <-> && "$route_target" -gt 0 ]]; then
      fail "No route numbered $route_target in $found_tunnel_name"
    else
      fail "No route for $route_target in $found_tunnel_name"
    fi
  fi

  existing_hostname="${existing_route%%$'\t'*}"
  existing_service="${existing_route#*$'\t'}"

  if [[ -z "$new_hostname" ]]; then
    new_hostname="$existing_hostname"
  fi

  if [[ "$new_hostname" != "$existing_hostname" ]]; then
    duplicate="$(jq -r --arg hostname "$new_hostname" --arg existing_hostname "$existing_hostname" '
      any(.ingress[]?; .hostname == $hostname and .hostname != $existing_hostname)
    ' <<< "$config")"

    if [[ "$duplicate" == true ]]; then
      fail "Route already exists for $new_hostname in $found_tunnel_name"
    fi
  fi

  if [[ "$route_target" == <-> && "$route_target" -gt 0 ]]; then
    new_config="$(jq --argjson route_number "$route_target" --arg hostname "$new_hostname" --arg service "$new_service" '
      .ingress = (
        (.ingress // []) as $ingress
        | reduce $ingress[] as $rule (
            {routes_seen: 0, rules: []};
            if $rule.hostname != null then
              .routes_seen += 1
              | if .routes_seen == $route_number then
                  .rules += [$rule + {hostname: $hostname, service: $service}]
                else
                  .rules += [$rule]
                end
            else
              .rules += [$rule]
            end
          )
        | .rules
      )
    ' <<< "$config")"
  else
    new_config="$(jq --arg target_hostname "$route_target" --arg hostname "$new_hostname" --arg service "$new_service" '
      .ingress = ((.ingress // []) | map(if .hostname == $target_hostname then . + {hostname: $hostname, service: $service} else . end))
    ' <<< "$config")"
  fi

  payload="$(jq -n --argjson config "$new_config" '{config: $config}')"
  update_response="$(cf_api PUT "$(tunnel_config_path "$found_tunnel_id")" "$payload")"
  require_success "$update_response" "Failed to edit route in tunnel: $found_tunnel_name"
  write_route_cache_from_config "$new_config"

  if [[ "$new_hostname" != "$existing_hostname" ]]; then
    delete_dns_record "$existing_hostname"
    upsert_dns_record "$new_hostname"
  else
    upsert_dns_record "$new_hostname"
  fi

  log-status complete "Edited $existing_hostname -> $existing_service to $new_hostname -> $new_service in $found_tunnel_name"
}

add_route() {
  local selector="$1"
  local hostname="$2"
  local service="$3"
  local duplicate config new_config payload update_response

  find_tunnel "$selector"
  require_cached_config
  config="$cached_config"

  duplicate="$(jq -r --arg hostname "$hostname" '
    any(.ingress[]?; .hostname == $hostname)
  ' <<< "$config")"

  if [[ "$duplicate" == true ]]; then
    fail "Route already exists for $hostname in $found_tunnel_name"
  fi

  new_config="$(jq --arg hostname "$hostname" --arg service "$service" '
    .ingress = (
      (.ingress // []) as $ingress
      | {hostname: $hostname, service: $service} as $new_route
      | (reduce range(0; ($ingress | length)) as $i (
          null;
          if . == null and ($ingress[$i].hostname == null and $ingress[$i].path == null) then $i else . end
        )) as $fallback_index
      | if $fallback_index == null then
          $ingress + [$new_route]
        else
          $ingress[0:$fallback_index] + [$new_route] + $ingress[$fallback_index:]
        end
    )
  ' <<< "$config")"
  payload="$(jq -n --argjson config "$new_config" '{config: $config}')"

  update_response="$(cf_api PUT "$(tunnel_config_path "$found_tunnel_id")" "$payload")"
  require_success "$update_response" "Failed to add route to tunnel: $found_tunnel_name"
  write_route_cache_from_config "$new_config"

  upsert_dns_record "$hostname"

  log-status complete "Added $hostname -> $service to $found_tunnel_name"
}

case "${1:-}" in
  -h|--help)
    print_usage info
    exit 0
    ;;
  '')
    print_usage failed
    exit 2
    ;;
  tunnel|tunnels)
    require_command curl
    require_command jq
    load_env

    if [[ $# -ne 1 ]]; then
      print_usage failed
      exit 2
    fi
    list_tunnels
    ;;
  dns)
    require_command curl
    require_command jq
    load_env

    shift
    case "${1:-}" in
      add)
        shift
        if ! parse_dns_record_args "$@" || [[ "${#parsed_dns_args[@]}" -ne 2 ]]; then
          print_usage failed
          exit 2
        fi
        add_dns_record "$parsed_dns_args[1]" "$parsed_dns_type" "$parsed_dns_args[2]"
        ;;
      edit)
        shift
        if ! parse_dns_record_args "$@" || [[ "${#parsed_dns_args[@]}" -ne 2 ]]; then
          print_usage failed
          exit 2
        fi
        edit_dns_record "$parsed_dns_args[1]" "$parsed_dns_type" "$parsed_dns_args[2]"
        ;;
      delete|remove)
        shift
        if [[ $# -ne 1 ]]; then
          print_usage failed
          exit 2
        fi
        delete_any_dns_record "$1"
        ;;
      *)
        print_usage failed
        exit 2
        ;;
    esac
    ;;
  route|routes)
    require_command curl
    require_command jq
    load_env

    shift
    if [[ $# -lt 1 ]]; then
      print_usage failed
      exit 2
    fi

    selector_parts=()
    while [[ $# -gt 0 && "$1" != add && "$1" != edit && "$1" != delete && "$1" != remove ]]; do
      selector_parts+=("$1")
      shift
    done

    selector="${(j: :)selector_parts}"
    if [[ -z "$selector" ]]; then
      print_usage failed
      exit 2
    fi

    case "${1:-}" in
      add)
        shift
        if [[ $# -ne 2 ]]; then
          print_usage failed
          exit 2
        fi
        add_route "$selector" "$1" "$2"
        ;;
      edit)
        shift
        if [[ $# -eq 2 ]]; then
          edit_route "$selector" "$1" "" "$2"
        elif [[ $# -eq 3 ]]; then
          edit_route "$selector" "$1" "$2" "$3"
        else
          print_usage failed
          exit 2
        fi
        ;;
      delete|remove)
        shift
        if [[ $# -ne 1 ]]; then
          print_usage failed
          exit 2
        fi
        delete_route "$selector" "$1"
        ;;
      '')
        list_routes "$selector"
        ;;
      *)
        print_usage failed
        exit 2
        ;;
    esac
    ;;
  *)
    log-status failed "Unknown command: $1"
    print_usage failed
    exit 2
    ;;
esac
