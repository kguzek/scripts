#!/usr/bin/env zsh

set -e
program_name="${0:t}"

zmodload zsh/datetime || {
  log-status failed "$program_name: failed to load zsh/datetime"
  exit 1
}

current_time() {
  print -r -- "$EPOCHREALTIME"
}

case "${1:-}" in
  --start)
    printf 'export time_script_measurement_start_time=%q\n' "$(current_time)"
    ;;
  --end)
    if [[ -z ${time_script_measurement_start_time:-} ]]; then
      log-status failed "$program_name: missing time_script_measurement_start_time; run: source <($program_name --start)"
      exit 1
    fi

    start_time="$time_script_measurement_start_time"
    end_time=$(current_time)
    elapsed=$(($end_time - $start_time))
    printf '%.3f\n' "$elapsed"
    ;;
  *)
    log-status failed "Usage: ${0:t} --start|--end"
    exit 2
    ;;
esac
