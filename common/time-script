#!/usr/bin/env zsh

set -e
program_name="${0:t}"

if ! zmodload zsh/datetime; then
  log-status failed "$program_name: failed to load zsh/datetime"
  exit 1
fi

case "${1:-}" in
  --start)
    printf 'export time_script_measurement_start_time=%q\n' "$EPOCHREALTIME"
    ;;
  --end)
    if [[ -z ${time_script_measurement_start_time:-} ]]; then
      log-status failed "$program_name: missing time_script_measurement_start_time; run: source <($program_name --start)"
      exit 1
    fi

    start_time="$time_script_measurement_start_time"
    elapsed=$((EPOCHREALTIME - start_time))

    if (( elapsed < 1 )); then
      decimal_places=3
    elif (( elapsed < 10 )); then
      decimal_places=2
    else
      decimal_places=1
    fi

    printf "%.${decimal_places}f\n" "$elapsed"
    ;;
  *)
    log-status failed "Usage: ${0:t} --start|--end"
    exit 2
    ;;
esac
