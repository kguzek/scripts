#!/usr/bin/env zsh

set -e
program_name="${0:t}"

START_TIME_FILE_PATH='/tmp/time-script/start-time.txt'

if ! zmodload zsh/datetime; then
  log-status failed "$program_name: failed to load zsh/datetime"
  exit 1
fi

case "${1:-}" in
  --start)
    mkdir -p "${START_TIME_FILE_PATH:h}"
    printf '%s\n' "$EPOCHREALTIME" > "$START_TIME_FILE_PATH"
    ;;
  --end)
    if ! read -r start_time < "$START_TIME_FILE_PATH"; then
      log-status failed "$program_name: missing file $START_TIME_FILE_PATH; run: $program_name --start"
      exit 1
    fi

    elapsed=$((EPOCHREALTIME - start_time))

    if (( elapsed < 1 )); then
      decimal_places=3
    elif (( elapsed < 10 )); then
      decimal_places=2
    else
      decimal_places=1
    fi

    printf "%.${decimal_places}f\n" "$elapsed"
    ;;
  *)
    log-status failed "Usage: ${0:t} --start|--end"
    exit 2
    ;;
esac
